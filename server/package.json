{
  "name": "velozity-server",
  "version": "1.0.0",
  "description": "Real-Time Client Project Dashboard API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed": "tsx prisma/seed.ts",
